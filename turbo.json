{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "OWNER_LOGIN_SECRET",
    "OWNER_ACCESS_CODE",
    "SITE_URL",
    "SITE_PORT",
    "GITHUB_MOCK_MODE",
    "GITHUB_TOKEN",
    "GITHUB_WEBHOOK_SECRET",
    "VAULT_ENCRYPTION_KEY"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**"
      ],
      "env": [
        "DATABASE_URL",
        "OWNER_LOGIN_SECRET",
        "OWNER_ACCESS_CODE",
        "SITE_URL",
        "SITE_PORT"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ]
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:e2e": {
      "cache": false
    },
    "format": {}
  }
}
