{
  "name": "savigesystemz-com",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "SavigeSystemZ flagship platform monorepo",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "node scripts/dev-web.mjs",
    "build:web": "node scripts/build-web.mjs",
    "code:sync-org": "pnpm --filter web code:sync-org",
    "code:seed-apps": "pnpm --filter web code:seed-apps",
    "code:generate-showcases": "pnpm --filter web code:generate-showcases",
    "code:fetch-screenshots": "pnpm --filter web code:fetch-screenshots",
    "code:capture-ui-screenshots": "pnpm --filter web code:capture-ui-screenshots",
    "code:discover-launches": "pnpm --filter web code:discover-launches",
    "code:refresh-showcase": "pnpm --filter web code:refresh-showcase",
    "code:seed-releases": "pnpm --filter web code:seed-releases",
    "code:bootstrap": "node scripts/bootstrap-foundry.mjs",
    "code:verify-catalog": "pnpm --filter web code:verify-catalog",
    "staging:verify": "pnpm --filter web staging:verify",
    "verify:release": "bash scripts/verify-release.sh",
    "start:web": "pnpm --filter web start",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "turbo run format",
    "audit:deps": "pnpm audit --prod || true",
    "check:all": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
