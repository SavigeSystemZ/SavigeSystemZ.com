# Public site URL (sitemap, metadata, absolute links)
SITE_URL="http://127.0.0.1:43907"
# Local dev server canonical port — dev-web.mjs prefers this when free.
# Override per-shell with `SITE_PORT=xxxxx pnpm dev:web`.
SITE_PORT=43907
# PostgreSQL (primary): start local Postgres with `docker compose -f docker-compose.postgres.yml up -d`
DATABASE_URL="postgresql://ssz:dev@localhost:5433/savige"
# SQLite (quick local dev): use `./scripts/dev-sqlite.sh` instead
# DATABASE_URL="file:./dev.db"
OWNER_ACCESS_CODE="set-a-long-random-owner-code"
OWNER_LOGIN_SECRET="set-a-long-random-signing-secret"
# 64 hex chars (32 bytes). Required to persist encrypted vault rows (see docs/VAULT.md).
VAULT_ENCRYPTION_KEY=
# Optional: previous primary key — decrypt-only for rotation (see docs/VAULT_KEY_ROTATION.md).
VAULT_ENCRYPTION_KEY_LEGACY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_PURCHASE_AMOUNT_CENTS=999
DOWNLOAD_SIGNING_SECRET=
# Local dev: use 127.0.0.1 and match SITE_URL. Production: your real domain and https origin.
PASSKEY_RP_ID=127.0.0.1
PASSKEY_RP_NAME=SavigeSystemZ
PASSKEY_ORIGIN=http://127.0.0.1:43907
PASSKEY_REQUIRE_USER_VERIFICATION=1
AWS_REGION=us-east-1
AWS_S3_PRESIGN_ENABLED=
# Optional: dedicated bucket for vault PUT (presigned). Keys are forced to vault/<ownerUserId>/…
AWS_S3_VAULT_BUCKET=
# Optional: KMS key id for SSE-KMS on vault PUT (see docs/S3_VAULT_HARDENING.md)
AWS_S3_VAULT_SSE_KMS_KEY_ID=
# Optional: shared Redis for vault POST + s3-upload-url rate limits across instances (see docs/RATE_LIMITS.md)
# REDIS_URL=redis://127.0.0.1:6379
# Optional: if REDIS_URL is set, require Redis (503 on failure) instead of in-memory fallback
# VAULT_REDIS_STRICT=1

# Optional: GitHub Personal Access Token for higher API rate limits + private repo access.
# Fine-grained PAT with read-only metadata + contents is sufficient for the admin /code panel.
GITHUB_TOKEN=
