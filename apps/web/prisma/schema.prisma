generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  auditLogs AuditLog[]
  sessions  Session[]
  licenses  License[]
  passkeys  PasskeyCredential[]
  passkeyChallenges PasskeyChallenge[]
  vaultArtifacts VaultArtifact[]
}

model Application {
  id          String               @id @default(cuid())
  slug        String               @unique
  name        String
  summary     String
  visibility  ApplicationVisibility @default(DRAFT)
  featured    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  versions    ApplicationVersion[]
  licenses    License[]
  purchases   Purchase[]

  @@index([visibility, featured])
}

model ApplicationVersion {
  id            String       @id @default(cuid())
  applicationId String
  version       String
  changelog     String
  createdAt     DateTime     @default(now())
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  assets        ReleaseAsset[]

  @@unique([applicationId, version])
  @@index([applicationId])
  @@index([applicationId, createdAt])
}

model ReleaseAsset {
  id          String             @id @default(cuid())
  versionId   String
  fileName    String
  fileUrl     String
  /// When set with s3Key, `/api/files/signed` may redirect to a presigned GET URL instead of fileUrl.
  s3Bucket    String?
  s3Key       String?
  checksum    String?
  visibility  AssetVisibility    @default(PUBLIC)
  createdAt   DateTime           @default(now())
  version     ApplicationVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  downloads   DownloadEvent[]

  @@index([versionId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasskeyCredential {
  id            String   @id @default(cuid())
  userId        String
  credentialId  String   @unique
  publicKey     String
  counter       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model License {
  id            String   @id @default(cuid())
  userId        String
  applicationId String
  status        LicenseStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  stripeCheckoutSessionId String? @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId, applicationId])
}

model Purchase {
  id                      String   @id @default(cuid())
  stripeCheckoutSessionId String   @unique
  applicationId           String
  purchaserEmail          String
  status                  PurchaseStatus @default(PENDING)
  createdAt               DateTime @default(now())
  completedAt             DateTime?
  application             Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@index([createdAt])
}

model PasskeyChallenge {
  id          String               @id @default(cuid())
  /// Null for discoverable-style login challenges (resolved via credential id after verify).
  userId      String?
  kind        PasskeyChallengeKind @default(AUTHENTICATION)
  challenge   String               @unique
  expiresAt   DateTime
  createdAt   DateTime             @default(now())
  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

enum PasskeyChallengeKind {
  REGISTRATION
  AUTHENTICATION
}

model DownloadEvent {
  id           String   @id @default(cuid())
  userId       String?
  releaseAssetId String
  createdAt    DateTime @default(now())
  releaseAsset ReleaseAsset @relation(fields: [releaseAssetId], references: [id], onDelete: Cascade)

  @@index([releaseAssetId])
  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  metadata    String?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([actorUserId])
  @@index([targetType, targetId])
}

/// Owner-scoped encrypted vault row (payload is AES-256-GCM JSON: note + tags).
model VaultArtifact {
  id            String   @id @default(cuid())
  ownerUserId   String
  createdAt     DateTime @default(now())
  payloadCipher String
  /// Ciphertext key epoch; matches `VAULT_STORED_KEY_VERSION` in app code until format changes.
  keyVersion    Int      @default(1)
  owner         User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
}

model ProjectRequest {
  id           String                @id @default(cuid())
  title        String
  description  String
  contactEmail String?
  status       ProjectRequestStatus  @default(PENDING)
  sourceIp     String?
  /// When set, the row is hidden from default admin lists (soft-delete / archive).
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([deletedAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

enum ProjectRequestStatus {
  PENDING
  REVIEWING
  CLOSED
}

enum Role {
  USER
  OWNER
}

enum ApplicationVisibility {
  PUBLIC
  PRIVATE
  DRAFT
}

enum AssetVisibility {
  PUBLIC
  ENTITLED
  PRIVATE
}

enum LicenseStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}
