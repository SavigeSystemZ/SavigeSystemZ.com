# Staging / pre-production (copy to your secrets store or `apps/web/.env.staging.local` — never commit real values)
# Use PostgreSQL here; local dev may stay on SQLite. Switch `provider` in `apps/web/prisma/schema.prisma` to `postgresql`
# before running migrations against this URL (see docs/DATABASE.md and docs/DB_MIGRATION_PLAN.md).

NODE_ENV=production
NEXT_PUBLIC_APP_NAME=SavigeSystemZ

# Managed Postgres (Neon, RDS, Supabase, etc.) — require TLS in cloud
DATABASE_URL=postgresql://app_user:CHANGE_ME@db.example.com:5432/savigesystemz_staging?sslmode=require

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_PURCHASE_AMOUNT_CENTS=999
DOWNLOAD_SIGNING_SECRET=

OWNER_ACCESS_CODE=
OWNER_LOGIN_SECRET=

# Vault at-rest encryption (must match between app instances)
VAULT_ENCRYPTION_KEY=
VAULT_ENCRYPTION_KEY_LEGACY=

AWS_REGION=us-east-1
AWS_S3_PRESIGN_ENABLED=
AWS_S3_VAULT_BUCKET=
AWS_S3_VAULT_SSE_KMS_KEY_ID=

# Optional: ElastiCache / Upstash / Redis Cloud — vault mutation rate limits (multi-instance)
# REDIS_URL=rediss://default:CHANGE_ME@your-redis.example.com:6379
# Recommended with managed Redis: fail closed when limiter is unavailable
# VAULT_REDIS_STRICT=1

PASSKEY_RP_ID=staging.example.com
PASSKEY_ORIGIN=https://staging.example.com
