NODE_ENV=development
NEXT_PUBLIC_APP_NAME=SavigeSystemZ
DATABASE_URL=postgres://user:pass@localhost:5432/savigesystemz
DATABASE_URL_PROD=postgresql://user:pass@db-host:5432/savigesystemz?sslmode=require
SENTRY_DSN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DEFAULT_PURCHASE_AMOUNT_CENTS=999
DOWNLOAD_SIGNING_SECRET=
OWNER_ACCESS_CODE=
OWNER_LOGIN_SECRET=
AWS_REGION=
AWS_S3_PRESIGN_ENABLED=
# Staging/production buckets for admin upload lanes (release assets + application media presign routes).
AWS_S3_RELEASE_BUCKET=
AWS_S3_RELEASE_SSE_KMS_KEY_ID=
AWS_S3_MEDIA_BUCKET=
AWS_S3_MEDIA_SSE_KMS_KEY_ID=
# Optional vault bucket (see apps/web/.env.example AWS_S3_VAULT_BUCKET)
# IAM user/role needs s3:PutObject on the buckets above; verify via /admin/launch on staging.
